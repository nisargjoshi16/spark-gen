# Production (Oracle systemd / GitHub Actions deploy)
NODE_ENV=production
# Oracle VM serves HTTP only — must be false or login cookies are rejected by the browser
COOKIE_SECURE=false
HOSTNAME=0.0.0.0
PORT=3000

# Team login — required in production (proxy gates the whole app)
APP_PASSWORD=change-me-team-password

# Signs session cookies; use a long random string (falls back to APP_PASSWORD if unset)
AUTH_SECRET=change-me-long-random-secret

# Optional: for scripts/cron calling POST /api/generate with Authorization: Bearer ...
GENERATE_API_SECRET=change-me-api-key

# Org branding PINs — enforced server-side on export
ORG_PIN_PRACHODAYAT=16111982
ORG_PIN_SHARDUL=16111982