# Production (Oracle systemd / GitHub Actions deploy)
NODE_ENV=production
# false only for plain HTTP (e.g. :3000). Use true behind HTTPS nginx.
COOKIE_SECURE=true
HOSTNAME=0.0.0.0
PORT=3000

# Legacy: enables auth gate if set (login uses per-org ORG_PIN_* below)
APP_PASSWORD=

# Per-organization login passwords (shown on login screen)
ORG_PIN_PRACHODAYAT=change-me-prachodayat-password
ORG_PIN_SHARDUL=change-me-shardul-password
ORG_PIN_GURUKUL=change-me-gurukul-password

# Signs session cookies; use a long random string (falls back to APP_PASSWORD if unset)
AUTH_SECRET=change-me-long-random-secret

# Optional: for scripts/cron calling POST /api/generate with Authorization: Bearer ...
GENERATE_API_SECRET=change-me-api-key

